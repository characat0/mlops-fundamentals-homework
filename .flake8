[flake8]
max-line-length = 100
extend-ignore = E203
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    env,
    build,
    dist,
    .dvc

per-file-ignores =
    # Scaffold imports provided for students to use in their TODO implementations
    model_serving/app/main.py: F401
    # Provided test files (kept verbatim): unused fixtures import + long assert messages
    data_pipeline/tests/test_process.py: F401,E501
    model_serving/tests/test_api.py: F401

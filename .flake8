[flake8]
max-line-length = 100
extend-ignore = E203
exclude = .venv, .git, __pycache__, build, dist, .dvc

per-file-ignores =
    # Scaffold imports provided for students to use in their TODO implementations
    model_serving/app/main.py: F401
    data_pipeline/tests/test_process.py: E501, F401
    model_serving/tests/test_api.py: E501, F401

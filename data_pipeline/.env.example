# MLOps Homework Environment Configuration

# MLflow tracking server URI
# Default: http://localhost:5000 (local server)
MLFLOW_TRACKING_URI=http://localhost:5000

# Optional: DVC remote storage (if using cloud storage)
# DVC_REMOTE_URL=s3://your-bucket/dvc-storage

# ---------------------------------------------------------------------
# Kaggle API authentication
# ---------------------------------------------------------------------
# Generate a token at https://www.kaggle.com/settings/api
# Click "Generate New Token" under the "API" section and copy the value.
#
# Option A (recommended): set KAGGLE_API_TOKEN here (single token, post-2025)
# Option B: leave blank and rely on the file at ~/.kaggle/access_token
#           (the CLI will pick it up automatically)
# Option C (legacy): provide KAGGLE_USERNAME and KAGGLE_KEY for a kaggle.json
#
# Do NOT commit a real token. Copy this file to `.env` and fill it locally.
KAGGLE_API_TOKEN=
# KAGGLE_USERNAME=
# KAGGLE_KEY=
